# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=

# Notion API Integration Key
NOTION_API_KEY=

# Notion Database ID (production)
NOTION_DATABASE_ID=

# Notion Database ID (for test mode, optional)
NOTION_DATABASE_ID_TEST=

# GitHub Token (for image hosting to generated-images branch)
GITHUB_TOKEN=

# GitHub Repository (format: owner/repo)
GITHUB_REPOSITORY=

# Optional: Override defaults
# MAX_ARTICLES=5
# LOOKBACK_DAYS=7
# TEST_MODE=false
# GEMINI_TEXT_MODEL=gemini-2.5-pro
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Optional: Override RSS feed URLs per source (overrides sources.json defaults)
# Set in GitHub Actions > Settings > Variables (or Secrets for private feeds)
# FEED_URL_OPENAI=https://openai.com/news/rss.xml
# FEED_URL_ANTHROPIC=https://raw.githubusercontent.com/0xSMW/rss-feeds/main/feeds/feed_anthropic_news.xml
# FEED_URL_GOOGLE_DEEPMIND=https://deepmind.google/blog/rss.xml
